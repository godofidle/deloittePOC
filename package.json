    {
      "staticPath": "assets/Images",
      "staticOutPath": "assets/Images"
    },
    {
      "staticPath": "assets/Templates",
      "staticOutPath": "assets/Templates"
    }
  ],
  "devDependencies": {
    "@parcel/transformer-sass": "^2.16.4",
    "gh-pages": "^6.3.0",
    "nodemon": "^2.0.4",
    "parcel": "^2.16.4",
    "parcel-reporter-static-files-copy": "^1.5.3",
    "sass": "^1.100.0"
  },
  "dependencies": {
    "bootstrap": "^4.5.2",
    "parcel-plugin-static-files-copy": "^2.5.0"
  }
